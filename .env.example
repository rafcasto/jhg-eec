# Copy to .env.local and fill in. NEVER commit real secrets.
SUPABASE_URL=
SUPABASE_SECRET_KEY=
# Optional: anon/publishable key, used for the admin password grant. Falls back
# to SUPABASE_SECRET_KEY when unset.
SUPABASE_ANON_KEY=
RESEND_API_KEY=
KIT_API_KEY=
# Kit sequence every signup is enrolled into. Defaults to
# "EEC \u2014 7 Job-Search Mistakes in the AI Era" (2833140) when unset.
KIT_SEQUENCE_ID=2833140

# --- Admin panel auth ---
# Signs the admin session cookie. Use a long random string in production.
ADMIN_SESSION_SECRET=

# Admin login uses Supabase Auth (GoTrue): admins sign in with their Supabase
# Auth email + password, and must be present in the public.admins allowlist.
# Manage admins with `npm run seed:admin` (uses SUPABASE_URL + SUPABASE_SECRET_KEY).

# Fallbacks — only used when Supabase is NOT configured (pure local dev):
#  - ADMIN_USERS: comma-separated `username:scryptHash` pairs, or a JSON array.
# ADMIN_USERS=alice:scrypt$...$...,bob:scrypt$...$...
#  - Legacy single password (username defaults to ADMIN_USERNAME, or "admin"):
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Optional convenience for seeding via .env instead of CLI flags:
# SEED_ADMIN_USERNAME=
# SEED_ADMIN_PASSWORD=
