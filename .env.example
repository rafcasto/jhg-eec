# Copy to .env.local and fill in. NEVER commit real secrets.
SUPABASE_URL=
SUPABASE_SECRET_KEY=
RESEND_API_KEY=
KIT_API_KEY=

# --- Admin panel auth ---
# Signs the admin session cookie. Use a long random string in production.
ADMIN_SESSION_SECRET=

# Admin logins are stored in Supabase on the public.admins table (email =
# username) in a password_hash column — run migration 0002_admins_password.sql,
# then seed users with `npm run seed:admin`. This uses SUPABASE_URL +
# SUPABASE_SECRET_KEY above.

# Fallbacks (used only when Supabase has no credential for the user):
#  - ADMIN_USERS: comma-separated `username:scryptHash` pairs, or a JSON array.
# ADMIN_USERS=alice:scrypt$...$...,bob:scrypt$...$...
#  - Legacy single password (username defaults to ADMIN_USERNAME, or "admin"):
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Optional convenience for seeding via .env instead of CLI flags:
# SEED_ADMIN_USERNAME=
# SEED_ADMIN_PASSWORD=
