# Copy to .env.local and fill in. NEVER commit real secrets.
SUPABASE_URL=
SUPABASE_SECRET_KEY=
RESEND_API_KEY=
KIT_API_KEY=

# --- Admin panel auth ---
# Signs the admin session cookie. Use a long random string in production.
ADMIN_SESSION_SECRET=

# Preferred: per-user credentials. Seed them with `npm run seed:admin`, which
# writes data/admin-users.json (gitignored) locally. For serverless hosts
# (e.g. Vercel) where that file isn't present, set ADMIN_USERS to a comma-
# separated list of `username:scryptHash` pairs (the seed script's --print
# flag outputs this value):
# ADMIN_USERS=alice:scrypt$...$...,bob:scrypt$...$...

# Optional convenience for seeding via .env instead of CLI flags:
# SEED_ADMIN_USERNAME=
# SEED_ADMIN_PASSWORD=

# Legacy single-password login (still works when no ADMIN_USERS are set).
# The username defaults to ADMIN_USERNAME, or "admin".
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
